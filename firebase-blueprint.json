{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A garment available in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "image", "category"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of all products in the store."
    }
  }
}
